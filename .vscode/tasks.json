{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build AutoTerrainDesignations",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "AutoTerrainDesignations.sln",
        "-c",
        "Debug"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Build AutoTerrainDesignations (Release)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "AutoTerrainDesignations.sln",
        "-c",
        "Release"
      ],
      "group": "build"
    },
    {
      "label": "Clean AutoTerrainDesignations",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "clean",
        "AutoTerrainDesignations.sln"
      ],
      "group": "build"
    },
    {
      "label": "Build AutoTerrainDesignations (Release with Package)",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "./build.ps1",
        "-Configuration",
        "Release",
        "-Package"
      ],
      "group": "build"
    }
  ]
}
